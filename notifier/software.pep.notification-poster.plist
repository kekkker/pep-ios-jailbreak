<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>software.pep.notification-poster</string>
	<key>ProgramArguments</key>
	<array>
		<string>/var/jb/bin/sh</string>
		<string>/var/jb/usr/libexec/pep-notification-poster-launcher</string>
	</array>
	<key>RunAtLoad</key>
	<true/>
	<key>KeepAlive</key>
	<true/>
	<key>ThrottleInterval</key>
	<integer>10</integer>
	<key>ProcessType</key>
	<string>Background</string>
	<key>UserName</key>
	<string>mobile</string>
	<key>StandardOutPath</key>
	<string>/var/mobile/Library/Logs/software.pep.notification-poster.log</string>
	<key>StandardErrorPath</key>
	<string>/var/mobile/Library/Logs/software.pep.notification-poster.log</string>
</dict>
</plist>
