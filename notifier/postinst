#!/bin/sh
set -e

launchctl bootout user/501/software.pep.notification-poster >/dev/null 2>&1 || true
launchctl bootout system/software.pep.notification-poster >/dev/null 2>&1 || true
launchctl bootout user/501/software.pep.notifier >/dev/null 2>&1 || true
launchctl bootout system/software.pep.notifier >/dev/null 2>&1 || true
rm -f /var/jb/Library/LaunchDaemons/software.pep.notification-poster.plist
rm -f /var/jb/usr/libexec/pep-notification-poster-launcher

# Version 1.1.1 is a clean notification-persistence baseline. Install the
# launchd definition, but leave it unloaded until foreground delivery has been
# verified after a SpringBoard restart.

exit 0
