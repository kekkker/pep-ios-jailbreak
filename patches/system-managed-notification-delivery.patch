+private struct PEPQueuedNotification: Codable {
+    let identifier: String
+    let title: String
+    let body: String
+}
+
+private enum PEPNotificationDeliveryQueue {
+    static let wakeRequestIdentifier = "pep-notification-delivery-wakeup"
+    private static let appGroupIdentifier = "group.software.pEp"
+    private static let directoryName = "notification-delivery-queue"
+
+    static var hasPendingNotifications: Bool {
+        return !queuedFiles().isEmpty
+    }
+
+    static func enqueue(title: String, body: String) -> Bool {
+        guard let directory = queueDirectory(create: true) else {
+            return false
+        }
+        let payload = PEPQueuedNotification(
+            identifier: "pep-mail-\(UUID().uuidString)",
+            title: title,
+            body: body)
+        let url = directory
+            .appendingPathComponent(payload.identifier)
+            .appendingPathExtension("json")
+        do {
+            try JSONEncoder().encode(payload).write(to: url, options: .atomic)
+            return true
+        } catch {
+            NSLog("pEp notification queue: enqueue failed: %@", "\(error)")
+            return false
+        }
+    }
+
+    static func deliverAll(completion: @escaping () -> Void) {
+        let files = queuedFiles()
+        guard !files.isEmpty else {
+            completion()
+            return
+        }
+
+        let center = UNUserNotificationCenter.current()
+        let group = DispatchGroup()
+        for file in files {
+            let payload: PEPQueuedNotification
+            do {
+                payload = try JSONDecoder().decode(
+                    PEPQueuedNotification.self,
+                    from: Data(contentsOf: file))
+            } catch {
+                NSLog("pEp notification queue: invalid payload: %@", "\(error)")
+                try? FileManager.default.removeItem(at: file)
+                continue
+            }
+
+            let content = UNMutableNotificationContent()
+            content.title = payload.title
+            content.body = payload.body
+            content.sound = .default
+            content.interruptionLevel = .active
+            let request = UNNotificationRequest(
+                identifier: payload.identifier,
+                content: content,
+                trigger: UNTimeIntervalNotificationTrigger(
+                    timeInterval: 1.0,
+                    repeats: false))
+
+            group.enter()
+            center.add(request) { error in
+                if let error = error {
+                    NSLog("pEp notification queue: delivery failed: %@",
+                          error.localizedDescription)
+                } else {
+                    try? FileManager.default.removeItem(at: file)
+                }
+                group.leave()
+            }
+        }
+
+        group.notify(queue: .main) {
+            DispatchQueue.main.asyncAfter(deadline: .now() + 1.25) {
+                completion()
+            }
+        }
+    }
+
+    private static func queuedFiles() -> [URL] {
+        guard let directory = queueDirectory(create: false) else {
+            return []
+        }
+        return (try? FileManager.default.contentsOfDirectory(
+            at: directory,
+            includingPropertiesForKeys: nil,
+            options: [.skipsHiddenFiles]))?
+            .filter { $0.pathExtension == "json" }
+            .sorted { $0.lastPathComponent < $1.lastPathComponent } ?? []
+    }
+
+    private static func queueDirectory(create: Bool) -> URL? {
+        guard let container = FileManager.default.containerURL(
+            forSecurityApplicationGroupIdentifier: appGroupIdentifier) else {
+            return nil
+        }
+        let directory = container.appendingPathComponent(
+            directoryName,
+            isDirectory: true)
+        if create {
+            do {
+                try FileManager.default.createDirectory(
+                    at: directory,
+                    withIntermediateDirectories: true,
+                    attributes: nil)
+            } catch {
+                NSLog("pEp notification queue: directory failed: %@", "\(error)")
+                return nil
+            }
+        }
+        return directory
+    }
+}
