+#ifndef PEPNotificationLauncher_h
+#define PEPNotificationLauncher_h
+
+#import <Foundation/Foundation.h>
+#import <UserNotifications/UserNotifications.h>
+#import <dlfcn.h>
+#import <objc/message.h>
+
+typedef id (*PEPObjectInitializer)(id, SEL, id);
+typedef id (*PEPTwoObjectFactory)(id, SEL, id, id);
+typedef void (*PEPBackgroundLaunchMessage)(id, SEL, id, id, id);
+
+NS_INLINE void PEPLaunchNotificationDelivery(
+    void (^completion)(BOOL launched)) {
+    void *handle = dlopen(
+        "/System/Library/PrivateFrameworks/"
+        "UserNotificationsServer.framework/UserNotificationsServer",
+        RTLD_LAZY);
+    Class launcherClass = NSClassFromString(@"UNSApplicationLauncher");
+    if (handle == NULL || launcherClass == Nil) {
+        completion(NO);
+        return;
+    }
+
+    UNMutableNotificationContent *content =
+        [[UNMutableNotificationContent alloc] init];
+    content.title = @"pEp mail delivery";
+    UNNotificationRequest *request =
+        [UNNotificationRequest
+            requestWithIdentifier:@"pep-notification-delivery-wakeup"
+            content:content
+            trigger:nil];
+    UNNotification *notification =
+        ((PEPTwoObjectFactory)objc_msgSend)(
+            [UNNotification class],
+            NSSelectorFromString(@"notificationWithRequest:date:"),
+            request,
+            [NSDate date]);
+    UNNotificationResponse *response =
+        ((PEPTwoObjectFactory)objc_msgSend)(
+            [UNNotificationResponse class],
+            NSSelectorFromString(
+                @"responseWithNotification:actionIdentifier:"),
+            notification,
+            UNNotificationDefaultActionIdentifier);
+    id launcher = ((PEPObjectInitializer)objc_msgSend)(
+        [launcherClass alloc],
+        NSSelectorFromString(@"initWithLocationMonitor:"),
+        nil);
+    if (launcher == nil || notification == nil || response == nil) {
+        completion(NO);
+        return;
+    }
+
+    void (^systemCompletion)(BOOL) = ^(BOOL launched) {
+        (void)launcher;
+        completion(launched);
+    };
+    ((PEPBackgroundLaunchMessage)objc_msgSend)(
+        launcher,
+        NSSelectorFromString(
+            @"backgroundLaunchApplication:withResponse:"
+             "completionHandler:"),
+        @"software.pEp.mail",
+        response,
+        systemCompletion);
+}
+
+#endif /* PEPNotificationLauncher_h */
