+/// Serializes access to pEp's Core Data store between the GUI process and the
+/// jailbreak daemon. The GUI asks the daemon to stop, then waits until the
+/// daemon has committed and exited before constructing MessageModel.
+private final class PEPDaemonOwnership {
+    private static let appGroupIdentifier = "group.software.pEp"
+    private static let takeoverNotification = "software.pep.native-notifier.takeover"
+    private var lockFileDescriptor: Int32 = -1
+
+    func acquireForGUI() -> Bool {
+        guard lockFileDescriptor == -1 else {
+            return true
+        }
+        guard let container = FileManager.default.containerURL(
+            forSecurityApplicationGroupIdentifier: Self.appGroupIdentifier) else {
+            NSLog("pEp daemon ownership: app-group container unavailable")
+            return false
+        }
+
+        let lockURL = container.appendingPathComponent("pep-mail-engine.lock")
+        let descriptor = open(lockURL.path, O_CREAT | O_RDWR, S_IRUSR | S_IWUSR)
+        guard descriptor >= 0 else {
+            NSLog("pEp daemon ownership: unable to open lock file (errno %d)", errno)
+            return false
         }
 
-        task.expirationHandler = {
-            messageModelService.cancelCheckForNewMails_old()
+        Self.takeoverNotification.withCString {
+            _ = systemNotifyPost($0)
         }
+        while flock(descriptor, LOCK_EX) != 0 {
+            if errno != EINTR {
+                NSLog("pEp daemon ownership: unable to acquire lock (errno %d)", errno)
+                close(descriptor)
+                return false
+            }
+        }
+        lockFileDescriptor = descriptor
+        return true
+    }
+
+    deinit {
+        if lockFileDescriptor >= 0 {
+            close(lockFileDescriptor)
+        }
+    }
+}
