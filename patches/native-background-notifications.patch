diff --git a/pEpForiOS/PEPNotificationLauncher.h b/pEpForiOS/PEPNotificationLauncher.h
new file mode 100644
index 0000000000000000000000000000000000000000..d4a53687026b60cd918cac8210096cbfd14295e0
--- /dev/null
+++ b/pEpForiOS/PEPNotificationLauncher.h
@@ -0,0 +1,84 @@
+#ifndef PEPNotificationLauncher_h
+#define PEPNotificationLauncher_h
+
+#import <Foundation/Foundation.h>
+#import <dlfcn.h>
+#import <objc/message.h>
+
+typedef id (*PEPNoArgumentObjectMessage)(id, SEL);
+typedef id (*PEPOneObjectFactory)(id, SEL, id);
+typedef void (*PEPOpenApplicationMessage)(id, SEL, id, id, id);
+
+NS_INLINE NSString *PEPFrontBoardStringSymbol(
+    void *handle,
+    const char *name) {
+    void *symbol = dlsym(handle, name);
+    return symbol == NULL ? nil : *(__unsafe_unretained NSString **)symbol;
+}
+
+NS_INLINE void PEPKeepBackgroundFetchActionAlive(id action) {
+    static id activeAction;
+    activeAction = action;
+}
+
+NS_INLINE void PEPLaunchNotificationDelivery(
+    void (^completion)(BOOL launched)) {
+    void *frontBoard = dlopen(
+        "/System/Library/PrivateFrameworks/"
+        "FrontBoardServices.framework/FrontBoardServices",
+        RTLD_LAZY);
+    void *uiKit = dlopen(
+        "/System/Library/PrivateFrameworks/UIKitCore.framework/UIKitCore",
+        RTLD_LAZY);
+    Class actionClass =
+        NSClassFromString(@"UIFetchContentInBackgroundAction");
+    Class optionsClass = NSClassFromString(@"FBSOpenApplicationOptions");
+    Class serviceClass = NSClassFromString(@"FBSOpenApplicationService");
+    NSString *actionsKey = PEPFrontBoardStringSymbol(
+        frontBoard,
+        "FBSOpenApplicationOptionKeyActions");
+    NSString *activateSuspendedKey = PEPFrontBoardStringSymbol(
+        frontBoard,
+        "FBSOpenApplicationOptionKeyActivateSuspended");
+    if (frontBoard == NULL || uiKit == NULL || actionClass == Nil ||
+        optionsClass == Nil || serviceClass == Nil || actionsKey == nil ||
+        activateSuspendedKey == nil) {
+        completion(NO);
+        return;
+    }
+
+    void (^actionHandler)(void) = ^{
+        PEPKeepBackgroundFetchActionAlive(nil);
+        completion(YES);
+    };
+    id action = ((PEPOneObjectFactory)objc_msgSend)(
+        [actionClass alloc],
+        NSSelectorFromString(@"initWithHandler:"),
+        actionHandler);
+    NSDictionary *dictionary = @{
+        actionsKey: @[action],
+        activateSuspendedKey: @YES
+    };
+    id options = ((PEPOneObjectFactory)objc_msgSend)(
+        optionsClass,
+        NSSelectorFromString(@"optionsWithDictionary:"),
+        dictionary);
+    id service = ((PEPNoArgumentObjectMessage)objc_msgSend)(
+        serviceClass,
+        NSSelectorFromString(@"serviceWithDefaultShellEndpoint"));
+    if (action == nil || options == nil || service == nil) {
+        completion(NO);
+        return;
+    }
+    PEPKeepBackgroundFetchActionAlive(action);
+
+    void (^openCompletion)(void) = ^{};
+    ((PEPOpenApplicationMessage)objc_msgSend)(
+        service,
+        NSSelectorFromString(@"openApplication:withOptions:completion:"),
+        @"software.pEp.mail",
+        options,
+        openCompletion);
+}
+
+#endif /* PEPNotificationLauncher_h */
