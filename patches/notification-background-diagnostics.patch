 /// A simple wrapper around Local Notification stuff
 struct UserNotificationTool {
+    private static let automaticSelfTestKey = "notificationSelfTest.ios16.v1"
+
     static public func askForPermissions() {
         let options: UNAuthorizationOptions = [.alert, .badge, .sound];
         let center = UNUserNotificationCenter.current()
-        center.requestAuthorization(options: options) { (granted, error) in }
+        center.requestAuthorization(options: options) { (granted, error) in
+            if let error = error {
+                Log.shared.warn("Notifications: authorization request failed: %@", error.localizedDescription)
+                return
+            }
+            Log.shared.warn("Notifications: authorization request completed; granted=%@",
+                            granted ? "yes" : "no")
+            logCurrentSettings()
+            if granted {
+                runAutomaticSelfTestOnce()
+            }
+        }
+    }
+
+    /// Posts a visible notification and returns a human-readable snapshot of every setting
+    /// involved. This is intentionally exposed in Settings so notification failures can be
+    /// diagnosed without attaching a debugger to a device.
+    static public func runSelfTest(completion: @escaping (String) -> Void) {
+        let center = UNUserNotificationCenter.current()
+        center.getNotificationSettings { settings in
+            DispatchQueue.main.async {
+                let summary = settingsSummary(settings)
+                guard authorizationAllowsNotifications(settings.authorizationStatus) else {
+                    completion(summary + "\n\nNo test was posted. Enable Notifications for p≡p in iOS Settings.")
+                    return
+                }
+
+                post(title: "p≡p notification test",
+                     body: "Notifications are working on this device.",
+                     identifier: "PEPNotificationSelfTest") { error in
+                    if let error = error {
+                        completion(summary + "\n\nTest failed: " + error.localizedDescription)
+                    } else {
+                        completion(summary + "\n\nTest posted successfully. A banner should appear now.")
+                    }
+                }
+            }
+        }
     }
 
     static public func post(title: String, body: String? = nil, batch: Int? = nil) {
+        post(title: title, body: body, batch: batch, identifier: "PEPLocalNotification") { _ in }
+    }
+
+    private static func post(title: String,
+                             body: String? = nil,
+                             batch: Int? = nil,
+                             identifier: String,
+                             completion: @escaping (Error?) -> Void) {
         // For some reason the notification is not triggered with timeInterval == nil
         let now = 0.01
         let center = UNUserNotificationCenter.current()
@@ -30,7 +77,6 @@ struct UserNotificationTool {
             content.badge = batch
         }
         content.sound = UNNotificationSound.default
-        let identifier = "PEPLocalNotification"
         let trigger = UNTimeIntervalNotificationTrigger(timeInterval: now, repeats: false)
         let request = UNNotificationRequest(identifier: identifier,
                                             content: content, trigger: trigger)
@@ -40,6 +86,95 @@ struct UserNotificationTool {
                     "Error posting user notification: %@",
                     "\(error)")
             }
+            completion(error)
+        }
+    }
+
+    private static func runAutomaticSelfTestOnce() {
+        let defaults = UserDefaults.standard
+        guard !defaults.bool(forKey: automaticSelfTestKey) else {
+            return
+        }
+        post(title: "p≡p notifications enabled",
+             body: "Local notifications work. Background mail delivery is checked separately.",
+             identifier: "PEPNotificationAutomaticSelfTest") { error in
+            if let error = error {
+                Log.shared.warn("Notifications: automatic self-test FAILED: %@",
+                                error.localizedDescription)
+            } else {
+                defaults.set(true, forKey: automaticSelfTestKey)
+                Log.shared.warn("Notifications: automatic self-test posted successfully")
+            }
+        }
+    }
+
+    private static func logCurrentSettings() {
+        UNUserNotificationCenter.current().getNotificationSettings { settings in
+            DispatchQueue.main.async {
+                Log.shared.warn("Notifications: %@", settingsSummary(settings))
+            }
+        }
+    }
+
+    private static func settingsSummary(_ settings: UNNotificationSettings) -> String {
+        return "Authorization: \(authorizationDescription(settings.authorizationStatus)); " +
+            "alerts: \(settingDescription(settings.alertSetting)); " +
+            "sounds: \(settingDescription(settings.soundSetting)); " +
+            "badges: \(settingDescription(settings.badgeSetting)); " +
+            "Background App Refresh: \(backgroundRefreshDescription())"
+    }
+
+    private static func authorizationAllowsNotifications(_ status: UNAuthorizationStatus) -> Bool {
+        switch status {
+        case .authorized, .provisional, .ephemeral:
+            return true
+        case .notDetermined, .denied:
+            return false
+        @unknown default:
+            return false
+        }
+    }
+
+    private static func authorizationDescription(_ status: UNAuthorizationStatus) -> String {
+        switch status {
+        case .notDetermined:
+            return "not requested"
+        case .denied:
+            return "denied"
+        case .authorized:
+            return "authorized"
+        case .provisional:
+            return "provisional"
+        case .ephemeral:
+            return "ephemeral"
+        @unknown default:
+            return "unknown"
+        }
+    }
+
+    private static func settingDescription(_ setting: UNNotificationSetting) -> String {
+        switch setting {
+        case .notSupported:
+            return "not supported"
+        case .disabled:
+            return "disabled"
+        case .enabled:
+            return "enabled"
+        @unknown default:
+            return "unknown"
+        }
+    }
+
+    private static func backgroundRefreshDescription() -> String {
+        switch UIApplication.shared.backgroundRefreshStatus {
+        case .available:
+            return "available"
+        case .denied:
+            return "denied"
+        case .restricted:
+            return "restricted"
+        @unknown default:
+            return "unknown"
         }
     }
 

