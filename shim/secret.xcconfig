// The open-source IMAP/SMTP client works without vendor OAuth credentials.
// Gmail and Yahoo OAuth buttons are disabled by using inert placeholder values.
OAUTH2_GMAIL_CLIENT_ID = unavailable
OAUTH2_GMAIL_REDIRECT_URL_SCHEME = software.pEp.mail
OAUTH2_YAHOO_CLIENT_ID = unavailable
OAUTH2_YAHOO_CLIENT_SECRET = unavailable
